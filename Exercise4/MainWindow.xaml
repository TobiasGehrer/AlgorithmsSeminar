<Window x:Class="Exercise4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wf="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        Title="Euler Graph Viewer" Height="650" Width="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8">
            <Button Content="📂 Datei laden"       Click="LoadFile_Click"   Margin="4" Padding="8,4"/>
            <Button Content="🔍 Euler prüfen"      Click="CheckEuler_Click" Margin="4" Padding="8,4"/>
            <Button Content="🛤 Eulerpfad anzeigen" Click="ShowPath_Click"   Margin="4" Padding="8,4"/>
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="#CCC" BorderThickness="1" Margin="8">
            <wf:WindowsFormsHost x:Name="GraphHost"/>
        </Border>

        <StackPanel Grid.Row="2" Margin="8,4">
            <StackPanel Orientation="Horizontal" Margin="0,4">
                <TextBox x:Name="SearchInput" Width="150" Margin="4,0" />
                <Button Content="DFS Rekursiv"  Click="DfsRec_Click"  Margin="4,0" Padding="8,4"/>
                <Button Content="DFS Iterativ"  Click="DfsIter_Click" Margin="4,0" Padding="8,4"/>
                <Button Content="BFS"           Click="Bfs_Click"     Margin="4,0" Padding="8,4"/>
            </StackPanel>
            <TextBlock x:Name="StatusText" Margin="4" FontSize="13"/>
            <TextBlock x:Name="MetricsText" Margin="4" FontSize="12" Foreground="Gray"/>
        </StackPanel>

        <!--<TextBlock Grid.Row="2" x:Name="StatusText" Margin="8,4" FontSize="13"/>-->
    </Grid>
</Window>
